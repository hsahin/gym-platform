{
  "name": "gym-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src next.config.mjs vitest.config.ts capacitor.config.ts --ext .js,.mjs,.ts,.tsx --max-warnings=0",
    "mobile:assets": "node scripts/generate-mobile-brand-assets.mjs",
    "mobile:privacy": "node scripts/harden-mobile-privacy.mjs",
    "mobile:sync": "npm run mobile:assets && cap sync && npm run mobile:privacy",
    "mobile:ios": "cap open ios",
    "mobile:android": "cap open android",
    "mobile:android:test:unit": "cd android && ./gradlew testDebugUnitTest",
    "mobile:android:test:instrumented:build": "cd android && ./gradlew :app:assembleDebugAndroidTest",
    "mobile:android:test:connected": "cd android && ./gradlew :app:connectedDebugAndroidTest",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "next typegen && tsc --noEmit",
    "ci:verify": "npm run lint && npm run typecheck && npm run build && npm run test:coverage"
  },
  "dependencies": {
    "@aparajita/capacitor-biometric-auth": "^10.0.0",
    "@aparajita/capacitor-secure-storage": "^8.0.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.3.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.3",
    "@capacitor/share": "^8.0.1",
    "@claimtech/auth": "0.2.3",
    "@claimtech/cache": "0.2.3",
    "@claimtech/core": "0.2.3",
    "@claimtech/database": "0.2.3",
    "@claimtech/feature-flags": "0.2.3",
    "@claimtech/i18n": "0.2.4",
    "@claimtech/messaging": "0.2.3",
    "@claimtech/ops": "0.2.4",
    "@claimtech/permissions": "0.2.3",
    "@claimtech/storage": "0.2.3",
    "@claimtech/tenant": "0.2.3",
    "@claimtech/users": "0.2.3",
    "@gravity-ui/icons": "^2.18.0",
    "@heroui-pro/react": "^1.0.0-beta.1",
    "@heroui/react": "^3.0.3",
    "@heroui/styles": "^3.0.3",
    "@number-flow/react": "^0.6.0",
    "@tailwindcss/postcss": "^4.2.4",
    "embla-carousel": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "next": "^15.5.15",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-aria-components": "^1.17.0",
    "react-dom": "^19.2.5",
    "react-resizable-panels": "^4.10.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^8",
    "eslint-config-next": "^15.5.15",
    "postcss": "^8.5.13",
    "tailwindcss": "^4.2.4",
    "typescript": "^5",
    "vitest": "4.1.4"
  },
  "overrides": {
    "fast-xml-parser": "^5.7.0",
    "postcss": "^8.5.13"
  }
}
