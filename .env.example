# Copy naar .env.local. Next.js laadt .env.example niet automatisch.
CLAIMTECH_SESSION_SECRET=replace-me
APP_ENV=development

# Production data. In productie zijn MONGODB_URI, MONGODB_DB_NAME en
# CLAIMTECH_SESSION_SECRET verplicht; er is geen lokale state- of cachefallback.
MONGODB_URI=
MONGODB_DB_NAME=gym-platform
REDIS_URL=
MONGODB_BACKUP_POLICY=
MIGRATIONS_LOCKED=
MONITORING_WEBHOOK_URL=
SENTRY_DSN=
SECURITY_HEADERS_ENABLED=true
APP_BASE_URL=

# Optional real smartdoor access
NUKI_API_TOKEN=
NUKI_API_BASE_URL=

# Optional real billing
MOLLIE_API_KEY=
MOLLIE_WEBHOOK_SECRET=

# Optional real messaging. Zodra WAHA of WhatsApp Cloud compleet is ingevuld,
# gebruikt de app live berichten; zonder configuratie worden berichten niet
# als verzonden geaccepteerd.
ENABLE_REAL_MESSAGES=false
WAHA_BASE_URL=
WAHA_API_KEY=
WAHA_SESSION=default
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Optional real uploads. Zodra Spaces compleet is ingevuld, worden waiver- en
# uploadpaden vrijgegeven; zonder configuratie blijft opslag niet beschikbaar.
ENABLE_REAL_UPLOADS=false
SPACES_BUCKET=
SPACES_ENDPOINT=https://ams3.digitaloceanspaces.com
SPACES_REGION=
SPACES_ACCESS_KEY_ID=
SPACES_SECRET_ACCESS_KEY=
# DigitalOcean noemt deze vaak korter; de app accepteert beide varianten.
SPACES_ACCESS_KEY=
SPACES_SECRET_KEY=
