CLAIMTECH_SESSION_SECRET=replace-me
LOCAL_PLATFORM_STATE_FILE=
PLATFORM_STATE_BACKEND=
APP_ENV=development

# Production data. In productie zijn MONGODB_URI, MONGODB_DB_NAME en
# CLAIMTECH_SESSION_SECRET verplicht; er is dan geen file/memory fallback.
MONGODB_URI=
MONGODB_DB_NAME=gym-platform
REDIS_URL=
MONGODB_BACKUP_POLICY=
MIGRATIONS_LOCKED=
MONITORING_WEBHOOK_URL=
SENTRY_DSN=
SECURITY_HEADERS_ENABLED=true

# Optional real messaging
ENABLE_REAL_MESSAGES=false
WAHA_BASE_URL=
WAHA_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Optional real uploads
ENABLE_REAL_UPLOADS=false
SPACES_BUCKET=
SPACES_ENDPOINT=
SPACES_REGION=
SPACES_ACCESS_KEY_ID=
SPACES_SECRET_ACCESS_KEY=
